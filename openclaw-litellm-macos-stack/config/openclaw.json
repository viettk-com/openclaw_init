{
  "agents": {
    "defaults": {
      "model": {
        "primary": "litellm/codex-oauth-gpt-5-1-codex"
      },
      "models": {
        "litellm/gpt-5.4": {
          "alias": "GPT-5.4 via LiteLLM"
        },
        "litellm/codex-oauth-gpt-5-1-codex": {
          "alias": "GPT-5.1 Codex via CLIProxyAPI"
        },
        "litellm/dlg-gpt-5-codex": {
          "alias": "GPT-5 Codex via DangLamGiau"
        },
        "litellm/dlg-gpt-5-1-codex-max": {
          "alias": "GPT-5.1 Codex Max via DangLamGiau"
        },
        "litellm/gpt-5.1-codex": {
          "alias": "GPT-5.1 Codex via LiteLLM"
        },
        "litellm/MiniMax-M2.5": {
          "alias": "MiniMax M2.5 via LiteLLM"
        },
        "litellm/MiniMax-M2.1": {
          "alias": "MiniMax M2.1 via LiteLLM"
        }
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "litellm": {
        "baseUrl": "http://litellm:4000",
        "apiKey": "${LITELLM_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "gpt-5.4",
            "name": "GPT-5.4",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 1050000,
            "maxTokens": 128000
          },
          {
            "id": "codex-oauth-gpt-5-1-codex",
            "name": "GPT-5.1 Codex (CLIProxyAPI)",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 400000,
            "maxTokens": 128000
          },
          {
            "id": "dlg-gpt-5-codex",
            "name": "GPT-5 Codex (DangLamGiau)",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 400000,
            "maxTokens": 128000
          },
          {
            "id": "dlg-gpt-5-1-codex-max",
            "name": "GPT-5.1 Codex Max (DangLamGiau)",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 400000,
            "maxTokens": 128000
          },
          {
            "id": "gpt-5.1-codex",
            "name": "GPT-5.1 Codex",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 400000,
            "maxTokens": 128000
          },
          {
            "id": "MiniMax-M2.5",
            "name": "MiniMax M2.5",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 196608,
            "maxTokens": 8192
          },
          {
            "id": "MiniMax-M2.1",
            "name": "MiniMax M2.1",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 196608,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "allowedOrigins": ["http://127.0.0.1:18789"]
    }
  },
  "browser": {
    "enabled": true,
    "defaultProfile": "chrome",
    "relayBindHost": "0.0.0.0",
    "executablePath": "/usr/local/bin/openclaw-playwright-chrome",
    "headless": true,
    "noSandbox": true
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": ["7121054800"],
      "groupPolicy": "allowlist",
      "groupAllowFrom": ["7121054800"],
      "configWrites": false,
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  }
}
