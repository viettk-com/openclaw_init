# ---------- Image pinning ----------
# Pin these to a known-good release tag or digest before production use.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
LITELLM_IMAGE=docker.litellm.ai/berriai/litellm:main-stable

# ---------- Docker project ----------
COMPOSE_PROJECT_NAME=openclawstack

# ---------- Host bind addresses ----------
OPENCLAW_BIND_HOST=127.0.0.1
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan

LITELLM_BIND_HOST=127.0.0.1
LITELLM_PORT=4000
LITELLM_HEALTH_PORT=8001

# ---------- OpenClaw ----------
# Optional: set a gateway token if you want an explicit shared secret for browser/device pairing flows.
OPENCLAW_GATEWAY_TOKEN=

# ---------- Telegram ----------
TELEGRAM_BOT_TOKEN=

# ---------- LiteLLM ----------
# Use a strong random value starting with sk-
LITELLM_MASTER_KEY=sk-change-me-master
# Use a second strong random value starting with sk- ; do not change after storing provider keys.
LITELLM_SALT_KEY=sk-change-me-salt

# Easiest first boot: set this equal to the master key.
# Better after bootstrap: generate a dedicated virtual key for OpenClaw and put it here instead.
LITELLM_API_KEY=sk-change-me-master

# ---------- Upstream provider keys ----------
OPENAI_API_KEY=
# Additional OpenAI keys for LiteLLM load balancing / failover.
# Leave blank if unused; the render script will skip empty entries.
OPENAI_API_KEY_2=
OPENAI_API_KEY_3=
OPENAI_API_KEY_4=
ANTHROPIC_API_KEY=
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.io/v1

# ---------- DangLamGiau / HOCAI marketplace ----------
# OpenAI-compatible upstream marketplace. Keep disabled until you add a real key.
DANGLAMGIAU_ENABLE=0
DANGLAMGIAU_API_KEY=
DANGLAMGIAU_API_BASE=https://danglamgiau.com/v1
# Start with a small, explicit allowlist. After adding a key, run
# ./scripts/discover-danglamgiau-models.sh and then adjust this list to match /v1/models.
DANGLAMGIAU_MODEL_PREFIX=dlg
DANGLAMGIAU_MODELS=gpt-5,gpt-5-codex,gpt-5.1-codex-max

# ---------- CLIProxyAPI bridge ----------
# Enable only when you want LiteLLM to call a local CLIProxyAPI instance for OAuth/subscription-backed models.
CLIPROXY_ENABLE=0
CLIPROXY_PORT=8317
CLIPROXY_API_KEY=cliproxy-change-me
CLIPROXY_API_BASE=http://host.docker.internal:8317/v1
CLIPROXY_MODELS=gpt-5-codex,gpt-5.1-codex,gpt-5.1-codex-max
# Optional: enables local-only web management/login at /management.html
CLIPROXY_MANAGEMENT_KEY=

# ---------- LiteLLM Postgres ----------
POSTGRES_DB=litellm
POSTGRES_USER=litellm
POSTGRES_PASSWORD=change-me-postgres
