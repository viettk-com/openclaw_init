# ---------- Image pinning ----------
# Pin these to a known-good release tag or digest before production use.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
LITELLM_IMAGE=docker.litellm.ai/berriai/litellm:main-stable

# ---------- Docker project ----------
COMPOSE_PROJECT_NAME=openclawstack

# ---------- Host bind addresses ----------
OPENCLAW_BIND_HOST=127.0.0.1
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan

LITELLM_BIND_HOST=127.0.0.1
LITELLM_PORT=4000
LITELLM_HEALTH_PORT=8001

# ---------- OpenClaw ----------
# Optional: set a gateway token if you want an explicit shared secret for browser/device pairing flows.
OPENCLAW_GATEWAY_TOKEN=

# ---------- Telegram ----------
TELEGRAM_BOT_TOKEN=

# ---------- LiteLLM ----------
# Use a strong random value starting with sk-
LITELLM_MASTER_KEY=sk-change-me-master
# Use a second strong random value starting with sk- ; do not change after storing provider keys.
LITELLM_SALT_KEY=sk-change-me-salt

# Easiest first boot: set this equal to the master key.
# Better after bootstrap: generate a dedicated virtual key for OpenClaw and put it here instead.
LITELLM_API_KEY=sk-change-me-master

# ---------- Upstream provider keys ----------
OPENAI_API_KEY=
# Additional OpenAI keys for LiteLLM load balancing / failover.
# Leave blank if unused; the render script will skip empty entries.
OPENAI_API_KEY_2=
OPENAI_API_KEY_3=
OPENAI_API_KEY_4=
ANTHROPIC_API_KEY=
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.io/v1

# ---------- LiteLLM Postgres ----------
POSTGRES_DB=litellm
POSTGRES_USER=litellm
POSTGRES_PASSWORD=change-me-postgres
